# macOS
.DS_Store

# Xcode
DerivedData/
*.xcuserstate
xcuserdata/
*.moved-aside
*.xcscmblueprint
# Xcode user-specific files / schemes that often contain secrets
*.xccheckout
xcshareddata/

# Build products
build/
*.ipa
*.dSYM
*.dSYM.zip

# SwiftPM
.build/
Packages/
Package.resolved

# CocoaPods (if you use it)
Pods/

# Carthage (if used)
Carthage/Build/

# Fastlane (if used)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output

# Claude Code local settings
.claude/settings.local.json

# Python
tools/__pycache__/

# Tile image sets — all generated images (regenerable from prompts.json + scripts)
# Masters will move to LFS when Kurt joins; optimized committed only when wired into app
tools/tile_sets/playful_3d/*.png
tools/tile_sets/high_contrast/*.png
tools/tile_sets/optimized/
tools/tile_sets/current/

# Review tool artifacts (regenerable)
tools/tile_sets/playful_3d/review/
tools/tile_sets/high_contrast/review/
tools/tile_sets/review_*.html
tools/tile_sets/*_failed.txt
tools/tile_sets/assets_link

# Downloaded symbol sets (large — re-download with tools scripts)
tools/sclera/

# Secrets / API keys
.env
*.secret
Config.swift
Secrets.swift
